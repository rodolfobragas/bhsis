// Prisma schema - imobiliarias module (placeholder)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/imobiliarias"
}

datasource db {
  provider = "postgresql"
  schemas  = ["bhsis"]
}

model ModuleMeta {
  id        String   @id @default(cuid())
  module    String   @default("imobiliarias")
  createdAt DateTime @default(now())

  @@schema("bhsis")
}
