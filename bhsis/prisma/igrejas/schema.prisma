// Prisma schema - igrejas module (placeholder)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/igrejas"
}

datasource db {
  provider = "postgresql"
  schemas  = ["bhsis"]
}

model ModuleMeta {
  id        String   @id @default(cuid())
  module    String   @default("igrejas")
  createdAt DateTime @default(now())

  @@schema("bhsis")
}
