<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>
  <entry key="web.port">8082</entry>
  <entry key="database.driver">org.h2.Driver</entry>
  <entry key="database.url">jdbc:h2:/opt/traccar/data/database</entry>
  <entry key="database.user">sa</entry>
  <entry key="database.password"></entry>
  <entry key="database.pool.maxIdle">20</entry>
  <entry key="database.pool.maxActive">50</entry>
  <entry key="database.pool.maxWait">10000</entry>
  <entry key="event.forward.enable">false</entry>
  <entry key="logging.level">INFO</entry>
</properties>
