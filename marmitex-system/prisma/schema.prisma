// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["marmitex"]
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ATTENDANT)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@schema("marmitex")
}

enum UserRole {
  ADMIN
  MANAGER
  KITCHEN
  ATTENDANT
  CUSTOMER
  @@schema("marmitex")
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String   @unique
  address   String?
  city      String?
  state     String?
  zipCode   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  deliveries Delivery[]
  loyaltyAccount LoyaltyAccount?

  @@index([phone])
  @@index([email])
  @@index([active])
  @@schema("marmitex")
}

// ============================================
// PRODUCTS & RECIPES
// ============================================

model Recipe {
  id          String   @id @default(cuid())
  name        String
  description String?
  ingredients String?
  instructions String?
  cost        Float    @default(0)
  prepTime    Int      @default(0) // in minutes
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([active])
  @@schema("marmitex")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  sku       String   @unique
  category  String
  price     Float
  recipeId  String?
  recipe    Recipe?  @relation(fields: [recipeId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems     OrderItem[]
  inventoryItems InventoryItem[]
  stockAlerts    StockAlert[]

  @@index([category])
  @@index([active])
  @@index([recipeId])
  @@schema("marmitex")
}

// ============================================
// INVENTORY & STOCK
// ============================================

model InventoryItem {
  id              String    @id @default(cuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Float     @default(0)
  minQuantity     Float     @default(10)
  maxQuantity     Float     @default(100)
  unit            String    @default("un")
  lastRestockDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  movements StockMovement[]
  alerts    StockAlert[]

  @@unique([productId])
  @@index([productId])
  @@schema("marmitex")
}

model StockMovement {
  id          String        @id @default(cuid())
  inventoryId String
  inventory   InventoryItem @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  type        MovementType
  quantity    Float
  reason      String?
  orderId     String?
  reference   String?
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([inventoryId])
  @@index([type])
  @@index([orderId])
  @@index([createdAt])
  @@schema("marmitex")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
  WASTE
  @@schema("marmitex")
}

model StockAlert {
  id          String        @id @default(cuid())
  inventoryId String
  inventory   InventoryItem @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  alertType   AlertType
  quantity    Float
  resolved    Boolean       @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([inventoryId])
  @@index([productId])
  @@index([alertType])
  @@index([resolved])
  @@schema("marmitex")
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  OVERSTOCK
  EXPIRING_SOON
  @@schema("marmitex")
}

enum DeliveryStatus {
  PENDENTE
  NA_ROTA
  EM_ENTREGA
  ENTREGUE
  CANCELADO
  @@schema("marmitex")
}

// ============================================
// ORDERS
// ============================================

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  status      OrderStatus @default(PENDING)
  paymentStatus OrderPaymentStatus @default(UNPAID)
  paymentMethod String?
  total       Float       @default(0)
  subtotal    Float       @default(0)
  tax         Float       @default(0)
  discount    Float       @default(0)
  couponId    String?
  coupon      Coupon?     @relation(fields: [couponId], references: [id])
  loyaltyPointsRedeemed Int @default(0)
  loyaltyPointsEarned   Int @default(0)
  tableId     String?
  table       DiningTable? @relation(fields: [tableId], references: [id])
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  completedAt DateTime?

  items      OrderItem[]
  deliveries Delivery[]
  payments   Payment[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([orderNumber])
  @@index([couponId])
  @@index([tableId])
  @@schema("marmitex")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
  @@schema("marmitex")
}

enum OrderPaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  @@schema("marmitex")
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  @@schema("marmitex")
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider  String        @default("stripe")
  status    PaymentStatus @default(PENDING)
  amount    Int
  currency  String        @default("brl")
  stripePaymentIntentId String? @unique
  stripeCheckoutSessionId String? @unique
  stripeCustomerId String?
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([provider])
  @@schema("marmitex")
}

enum CouponType {
  PERCENT
  FIXED
  @@schema("marmitex")
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  ADJUST
  @@schema("marmitex")
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  @@schema("marmitex")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
  @@schema("marmitex")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Float
  unitPrice Float
  total     Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@schema("marmitex")
}

model Coupon {
  id           String              @id @default(cuid())
  code         String              @unique
  description  String?
  type         CouponType
  value        Float
  minOrder     Float               @default(0)
  maxDiscount  Float?
  maxUses      Int?
  usesCount    Int                 @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  redemptions  CouponRedemption[]
  orders       Order[]

  @@index([code])
  @@index([active])
  @@schema("marmitex")
}

model CouponRedemption {
  id             String   @id @default(cuid())
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id])
  orderId        String?
  customerId     String?
  discountAmount Float    @default(0)
  createdAt      DateTime @default(now())

  @@index([couponId])
  @@index([orderId])
  @@index([customerId])
  @@schema("marmitex")
}

model LoyaltyAccount {
  id            String               @id @default(cuid())
  customerId    String               @unique
  customer      Customer             @relation(fields: [customerId], references: [id])
  pointsBalance Int                  @default(0)
  totalEarned   Int                  @default(0)
  totalRedeemed Int                  @default(0)
  tier          LoyaltyTier          @default(BRONZE)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  transactions  LoyaltyTransaction[]

  @@index([customerId])
  @@schema("marmitex")
}

model LoyaltyTransaction {
  id         String                  @id @default(cuid())
  accountId  String
  account    LoyaltyAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderId    String?
  type       LoyaltyTransactionType
  points     Int
  notes      String?
  createdAt  DateTime                @default(now())

  @@index([accountId])
  @@index([orderId])
  @@index([type])
  @@schema("marmitex")
}

model DiningTable {
  id             String      @id @default(cuid())
  name           String
  capacity       Int         @default(2)
  status         TableStatus @default(AVAILABLE)
  location       String?
  active         Boolean     @default(true)
  currentOrderId String?
  occupiedSince  DateTime?
  totalOccupiedMinutes Int   @default(0)
  turnovers      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orders Order[]

  @@index([status])
  @@index([active])
  @@schema("marmitex")
}

// ============================================
// SESSIONS (for Redis cache reference)
// ============================================

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@schema("marmitex")
}

model Motoboy {
  id              String           @id @default(cuid())
  nome            String
  telefone        String
  deviceIdTraccar String?          @map("device_id_traccar")
  ativo           Boolean          @default(true)
  deliveries      Delivery[]
  positions       PosicaoMotoboy[]
  routes          Rota[]
  @@schema("marmitex")
}

model Delivery {
  id              String          @id @default(cuid())
  orderId         String?         @map("order_id")
  order           Order?          @relation(fields: [orderId], references: [id])
  customerId      String?         @map("customer_id")
  customer        Customer?       @relation(fields: [customerId], references: [id])
  motoboyId       String?         @map("motoboy_id")
  motoboy         Motoboy?        @relation(fields: [motoboyId], references: [id])
  latitude        Decimal         @db.Decimal(10, 7)
  longitude       Decimal         @db.Decimal(10, 7)
  endereco        String
  status          DeliveryStatus  @default(PENDENTE)
  ordemRota       Int?            @map("ordem_rota")
  previsaoEntrega DateTime?       @map("previsao_entrega")
  createdAt       DateTime        @default(now()) @map("created_at")
  eventos         EventoEntrega[]
  @@schema("marmitex")
}

model EventoEntrega {
  id        String   @id @default(cuid())
  entregaId String   @map("entrega_id")
  entrega   Delivery @relation(fields: [entregaId], references: [id])
  tipo      String
  detalhes  Json?
  createdAt DateTime @default(now()) @map("created_at")
  @@schema("marmitex")
}

model PosicaoMotoboy {
  id        String   @id @default(cuid())
  motoboyId String   @map("motoboy_id")
  motoboy   Motoboy  @relation(fields: [motoboyId], references: [id])
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  speed     Decimal? @db.Decimal(6, 2)
  timestamp DateTime @default(now())
  @@schema("marmitex")
}

model Rota {
  id          String   @id @default(cuid())
  motoboyId   String   @map("motoboy_id")
  motoboy     Motoboy  @relation(fields: [motoboyId], references: [id])
  entregasIds Json     @default("[]") @map("entregas_ids")
  entregas    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  @@schema("marmitex")
}
